# =============================================================================
# WAHA - WhatsApp HTTP API - Variables de Entorno
# Copiar este archivo como .env y cambiar los valores
# Documentación: https://waha.devlike.pro/docs/how-to/config/
# =============================================================================

# =====================================================
# CREDENCIALES (¡OBLIGATORIO CAMBIAR!)
# Usar valores largos y aleatorios (tipo UUID)
# =====================================================

# API Key para autenticar las peticiones HTTP
WAHA_API_KEY=cambia-esto-por-un-uuid-largo-y-aleatorio

# Credenciales del Dashboard
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=cambia-esto-por-una-password-segura

# Credenciales del Swagger UI
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=cambia-esto-por-una-password-segura

# =====================================================
# CONFIGURACIÓN GENERAL
# =====================================================

# Dominio para Traefik
WAHA_DOMAIN=waha.tu-dominio.com

# URL base de tu servidor (ahora usando tu dominio)
WAHA_BASE_URL=https://waha.tu-dominio.com

# =====================================================
# WEBHOOKS (Para integración con n8n, etc.)
# =====================================================

# URL del webhook donde WAHA enviará los eventos
# WHATSAPP_HOOK_URL=http://tu-n8n:5678/webhook/waha

# Eventos a enviar al webhook (separados por coma)
# WHATSAPP_HOOK_EVENTS=message,message.any,state.change,group.join,group.leave

# =====================================================
# MOTOR DE WHATSAPP
# =====================================================

# Motor a usar: WEBJS (más completo) o NOWEB (más rápido y ligero)
# WHATSAPP_DEFAULT_ENGINE=WEBJS
